# Local project state — every consumer of this skill will gitignore these in their own repo
# (the skill's /bootstrap command ensures that). For the skill repo itself, we only ignore
# build byproducts.

# Editor
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Python artifacts (if test harness grows)
__pycache__/
*.pyc
.pytest_cache/
.venv/

# Consumer state � always local
docs/local/

# Skill memory — personal entries are per-install, never shipped.
# Track only the scaffold (README, _TEMPLATE, MEMORY.md header).
.claude/skills/*/memory/*.md
!.claude/skills/*/memory/README.md
!.claude/skills/*/memory/_TEMPLATE.md
!.claude/skills/*/memory/MEMORY.md

